# Local git worktrees (nested repos — never track as submodules)
.worktrees/

# Claude Code — personal overrides only. Everything else under .claude/
# (skills/, agents/, commands/, settings.json) is tracked so every agent
# landing in the repo gets the same CLI skills and pathways.
.claude/settings.local.json
.claude/worktrees/
.claude/projects/
.claude/todos/

# Internal frozen knowledge snapshots (super admin only — not for public repo)
docs/FROZEN_*.md

# Observability snapshots (runtime data, not source)
.paperclip/instances/default/observability-snapshots/

# Next.js / local app build artifacts under shipped worker-kit workspace apps
**/apps/workspace/.next/
**/apps/workspace/node_modules/

.paperclip/config.json
.paperclip/config.json.backup
*.tsbuildinfo

# Keep SDK package dist in source control for release tarball checks
!packages/api-contract/dist/
!packages/api-contract/dist/**
