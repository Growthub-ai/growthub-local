    "name": "Creative OS",
    "logoUrl": "",
    "accent": "#3f68ff"
  },
  "capabilities": [
    "dashboards",
    "canvas",
    "widgets",
    "bindings",
    "integrations",
    "settings"
  ],
  "pipelines": [],
  "integrations": [],
