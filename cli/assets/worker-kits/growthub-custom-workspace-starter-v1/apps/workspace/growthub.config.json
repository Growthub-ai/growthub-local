      {
        "id": "widget-welcome-creative-os",
        "kind": "rich-text",
        "title": "Welcome to Creative OS",
        "position": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 2
        },
        "config": {
          "text": "Your governed workspace is ready. Use the sidebar folders to open clients, campaigns, production tasks, assets, performance, and reports. All starter data lives in the Data Model — widgets only present it."
        }
      },
      {
        "id": "widget-campaigns-overview",
        "kind": "view",
        "title": "Campaigns",
        "position": {
          "x": 0,
          "y": 2,
          "w": 6,
          "h": 5
        },
        "config": {
          "layout": "Table",
          "source": "Campaigns",
          "columns": [],
          "rows": [],
          "binding": {
            "mode": "manual",
            "source": "Campaigns",
            "sourceType": "workspace-data-model",
            "sourceAuthority": "workspace-config",
            "objectId": "campaigns"
          }
        }
      },
      {
        "id": "widget-production-tasks-overview",
        "kind": "view",
        "title": "Production Tasks",
        "position": {
          "x": 6,
          "y": 2,
          "w": 6,
          "h": 5
        },
        "config": {
          "layout": "Table",
          "source": "Production Tasks",
          "columns": [],
          "rows": [],
          "binding": {
            "mode": "manual",
            "source": "Production Tasks",
            "sourceType": "workspace-data-model",
            "sourceAuthority": "workspace-config",
            "objectId": "production-tasks"
          }
        }
      }
    ],
    "bindings": {
      "chatToCanvas": true,
      "workflowOutputsToArtifacts": true,
      "sessionContext": true,
      "configDrivenCanvas": true
    }
  },
