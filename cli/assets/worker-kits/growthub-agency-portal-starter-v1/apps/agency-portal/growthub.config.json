{
  "id": "agency-portal-default",
  "name": "Agency Portal Dashboard",
  "description": "Default composition shipped by growthub-agency-portal-starter-v1. Stitches the production portalCapabilities catalog (apps/agency-portal/lib/domain/portal.js) and the Growthub MCP / BYO / static integration lanes (lib/domain/integrations.js) into a Twenty-style widget grid. Replace ids and bindings to tailor this composition to your forked workspace.",
  "capabilities": [
    "dashboard",
    "clients",
    "pipeline",
    "content",
    "tasks",
    "finance",
    "reports",
    "metrics",
    "client-results",
    "operations",
    "settings"
  ],
  "pipelines": [],
  "integrations": [
    "windsor-ai",
    "google-sheets-blended-data",
    "google-analytics",
    "shopify",
    "meta-ads"
  ],
  "canvas": {
    "id": "agency-canvas",
    "name": "Agency operating dashboard",
    "scope": "workspace",
    "layout": {
      "columns": 12,
      "rowHeight": 64,
      "gap": 16,
      "responsive": true
    },
    "widgets": [
      {
        "id": "mrr",
        "kind": "chart-metric",
        "title": "MRR",
        "chart": "number",
        "aggregate": "sum",
        "slug": "agencyMetric",
        "bindings": { "field": "mrr" },
        "position": { "x": 0, "y": 0, "w": 3, "h": 2 }
      },
      {
        "id": "pipeline-by-stage",
        "kind": "chart-metric",
        "title": "Pipeline by stage",
        "chart": "bar",
        "aggregate": "sum",
        "slug": "opportunity",
        "bindings": { "groupBy": "stage", "field": "value" },
        "position": { "x": 3, "y": 0, "w": 6, "h": 4 }
      },
      {
        "id": "client-health",
        "kind": "fields",
        "title": "Client health",
        "slug": "client",
        "bindings": { "fields": ["healthScore", "stage", "renewalDate"] },
        "position": { "x": 9, "y": 0, "w": 3, "h": 2 }
      },
      {
        "id": "windsor-status",
        "kind": "integration-card",
        "title": "Windsor AI",
        "slug": "windsor-ai",
        "bindings": { "lane": "data-source", "adapter": "growthub-bridge" },
        "position": { "x": 0, "y": 2, "w": 3, "h": 2 }
      },
      {
        "id": "open-tasks",
        "kind": "table",
        "title": "Open tasks",
        "slug": "task",
        "bindings": { "filters": [{ "field": "done", "op": "eq", "value": false }] },
        "position": { "x": 9, "y": 2, "w": 3, "h": 2 }
      },
      {
        "id": "agent-chat",
        "kind": "chat-session",
        "title": "Agent chat",
        "position": { "x": 0, "y": 4, "w": 4, "h": 4 }
      },
      {
        "id": "active-workflow",
        "kind": "workflow-runner",
        "title": "Active pipeline",
        "position": { "x": 4, "y": 4, "w": 4, "h": 4 }
      },
      {
        "id": "recent-artifacts",
        "kind": "artifact-viewer",
        "title": "Recent reports",
        "mediaPreview": true,
        "position": { "x": 8, "y": 4, "w": 4, "h": 4 }
      }
    ],
    "bindings": {
      "chatToCanvas": true,
      "workflowOutputsToArtifacts": true,
      "sessionContext": true,
      "portalCapabilities": true
    }
  },
  "provenance": {
    "createdBy": "cli",
    "note": "Shipped with growthub-agency-portal-starter-v1; safe to edit. Run `growthub compose preview` to validate after edits."
  }
}
