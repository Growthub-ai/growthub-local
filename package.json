{
  "name": "growthub-local",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "check:cli-package": "node ./scripts/check-cli-package.mjs",
    "check:version-sync": "node ./scripts/check-version-sync.mjs",
    "check:worker-kits": "node ./scripts/check-worker-kits.mjs",
